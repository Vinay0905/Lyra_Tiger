# Lyra API Keys
GROQ_API_KEY=your_groq_api_key_here

# Core Model Selections
GROQ_CHAT_MODEL=llama-3.3-70b-specdec
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
GROQ_STT_MODEL=distil-whisper-large-v3-en

# Security Guardrails
# Comma-separated absolute paths where Lyra is allowed to write and edit files.
APPROVED_WORKSPACE_DIRS=/Users/mast/Documents/VInayPrograming/AI_Assistant/sandbox

# Skill Settings
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=30000

# Voice Settings
# Options: local (macOS 'say' command), edge-tts (online), none (silent)
TTS_ENGINE=local
# macOS specific voice name (e.g., Samantha, Siri, Daniel)
MACOS_TTS_VOICE=Samantha

# System & Debug Configuration
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
