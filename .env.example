# ── API Keys ───────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── LLM routing ──────────────────────────────────────────────────────────────
# Comma-separated provider fallback order.
LLM_FALLBACK_CHAIN=groq

# Primary reasoning model (GROQ_CHAT_MODEL overrides GROQ_MODEL when set).
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=
# Small/fast tier used by the tiered intent router.
GROQ_SMALL_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
GROQ_STT_MODEL=whisper-large-v3

OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct

# ── Voice ────────────────────────────────────────────────────────────────────
# Kokoro voice id (e.g. af_sarah, af_bella, am_adam). Can be overridden per-request.
TTS_VOICE=af_sarah
# Optional: point to a directory containing bundled Kokoro weights.
# LYRA_KOKORO_DIR=/path/to/kokoro/resources

# ── Persistence & caching ────────────────────────────────────────────────────
LYRA_DB_PATH=lyra_store.db
LYRA_HISTORY_TURNS=8
LYRA_CLASSIFY_CACHE_TTL=600
LYRA_TTS_CACHE_SIZE=64

# ── Security guardrails ──────────────────────────────────────────────────────
# Comma-separated absolute paths where Lyra may write/edit files.
APPROVED_WORKSPACE_DIRS=/Users/mast/Documents/AI_Assistant/sandbox

# ── Kimi WebBridge ───────────────────────────────────────────────────────────
WEBBRIDGE_HOST=127.0.0.1
WEBBRIDGE_PORT=10086

# ── Server & debug ───────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LYRA_DEBUG=False
